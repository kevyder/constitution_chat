OPENAI_URL=https://api.openai.com/v1/
OPENAI_KEY=sk-or-v1-your-key-here

# Vector database (provider-agnostic)
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=
VECTOR_DB_COLLECTION_NAME=colombia_constitution

# Embeddings (vector dimension is auto-detected from the model on first ingest)
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_BATCH_SIZE=64

# Chat model (used by the Streamlit RAG app)
CHAT_MODEL=openai/gpt-4o-mini
RETRIEVER_TOP_K=5

# Source document
PDF_PATH=assets/constitucion-politica-colombia-1991.pdf
